// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique
  shortName String?
  logo      String
  teamPhoto String?

  /// [TeamWebContent]
  webContent Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeMatches Match[] @relation("HomeMatches")
  awayMatches Match[] @relation("AwayMatches")

  players Player[]
  staff   TeamStaff[]
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  POSTPONED
  CANCELED
}

model Match {
  id         String      @id @default(uuid()) @db.Uuid
  journey    Int
  kickoffAt  DateTime
  label      String
  status     MatchStatus @default(SCHEDULED)
  homeTeamId String      @db.Uuid
  awayTeamId String      @db.Uuid
  homeScore  Int?
  awayScore  Int?
  location   String?
  videoId    String?

  /// [MatchEvent[]]
  events Json?

  /// [MatchLineup]
  lineups Json?

  homeTeam Team @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayMatches", fields: [awayTeamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journey])
  @@index([status])
  @@index([kickoffAt])
}

enum PlayerPosition {
  GK
  DEF
  MID
  FWD
}

enum PlayerFoot {
  LEFT
  RIGHT
  BOTH
}

enum PlayerStatus {
  ACTIVE
  INJURED
  SUSPENDED
  UNAVAILABLE
  RETIRED
}

enum LeadershipRole {
  NONE
  CAPTAIN
  VICE_CAPTAIN
}

model Player {
  id             String         @id @default(uuid()) @db.Uuid
  firstName      String
  lastName       String
  fullName       String
  nickname       String?
  shirtNumber    Int?
  position       PlayerPosition
  preferredFoot  PlayerFoot
  dateOfBirth    DateTime?
  photo          String?
  bio            String?
  status         PlayerStatus   @default(ACTIVE)
  leadershipRole LeadershipRole @default(NONE)
  teamId         String         @db.Uuid
  team           Team           @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, shirtNumber])
  @@index([teamId])
  @@index([status])
  @@index([position])
}

enum StaffRole {
  COACH
  ASSISTANT_COACH
  DELEGATE
  PHYSICAL_PREPARATOR
}

model TeamStaff {
  id          String    @id @default(uuid()) @db.Uuid
  firstName   String
  lastName    String
  role        StaffRole
  dateOfBirth DateTime?
  photo       String?
  bio         String?
  teamId      String    @db.Uuid
  team        Team      @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([role])
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model News {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  slug        String     @unique
  excerpt     String
  content     String
  image       String?
  author      String
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([author])
  @@index([publishedAt])
  @@index([createdAt])
}

model Standing {
  id             String  @id @default(uuid()) @db.Uuid
  season         String
  competition    String  @default("Distrital")
  position       Int
  teamName       String
  teamLogo       String?
  gamesPlayed    Int     @default(0)
  wins           Int     @default(0)
  draws          Int     @default(0)
  losses         Int     @default(0)
  goalsFor       Int     @default(0)
  goalsAgainst   Int     @default(0)
  goalDifference Int     @default(0)
  points         Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, competition, teamName])
  @@unique([season, competition, position])
  @@index([season, competition])
  @@index([teamName])
}

model Testimonial {
  id       String  @id @default(uuid()) @db.Uuid
  quote    String
  author   String
  role     String
  initials String  @db.VarChar(4)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

